{
  "name": "Job Status Updater",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const text = $input.item.json.text;\nconst chatId = $input.item.json.chatId;\nconst replyToText = $input.item.json.replyToText;\n\nconst validCommands = ['applied', 'interview', 'rejected', 'offer', 'skip'];\n\nif (!validCommands.includes(text)) {\n  return [{\n    json: {\n      valid: false,\n      chatId,\n      reply: `Unknown command. Use one of: ${validCommands.join(', ')}`\n    }\n  }];\n}\n\n// Extract URL from original message\nconst urlMatch = replyToText.match(/https?:\\/\\/\\S+/);\nconst fullUrl = urlMatch ? urlMatch[0] : '';\n\nif (!fullUrl) {\n  return [{\n    json: {\n      valid: false,\n      chatId,\n      reply: 'Could not find job URL. Reply directly to a job alert message.'\n    }\n  }];\n}\n\n// Extract job_id from URL\nlet jobId = '';\n\n// Adzuna pattern\nconst adzunaMatch = fullUrl.match(/adzuna\\.com\\/land\\/ad\\/(\\d+)/);\nif (adzunaMatch) jobId = adzunaMatch[1];\n\n// Remotive pattern\nconst remotiveMatch = fullUrl.match(/-(\\d+)$/);\nif (remotiveMatch) jobId = remotiveMatch[1];\n\n// Arbeitnow pattern - uses slug as ID\nconst arbeitnowMatch = fullUrl.match(/arbeitnow\\.com\\/jobs\\/[^/]+\\/([^/?]+)/);\nif (arbeitnowMatch) jobId = arbeitnowMatch[1];\n\nreturn [{\n  json: {\n    valid: true,\n    status: text,\n    url: fullUrl,\n    job_id: jobId,\n    chatId,\n    reply: ''\n  }\n}];"
      },
