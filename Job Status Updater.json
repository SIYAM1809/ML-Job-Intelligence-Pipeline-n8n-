    {
      "parameters": {
        "jsCode": "const data = $input.item.json;\n\nif (!data.ok || !data.result || data.result.length === 0) {\n  return [];\n}\n\n// Only process messages that are replies\nconst replyMessages = data.result.filter(update => \n  update.message && \n  update.message.reply_to_message &&\n  update.message.text\n);\n\nif (replyMessages.length === 0) {\n  return [];\n}\n\nreturn replyMessages.map(update => ({\n  json: {\n    update_id: update.update_id,\n    text: update.message.text.toLowerCase().trim(),\n    chatId: update.message.chat.id,\n    replyToText: update.message.reply_to_message.text || ''\n  }\n}));"
      },
