      "parameters": {
        "jsCode": "const job = $input.item.json;\n\nreturn [{\n  json: {\n    job_id: String(job.id),\n    title: job.title || '',\n    company: job.company_name || '',\n    description: (job.description || '').replace(/<[^>]*>/g, '').substring(0, 3000),\n    location: job.candidate_required_location || 'Remote',\n    url: job.url || '',\n    tags: (job.tags || []).join(', '),\n    date_posted: job.publication_date || new Date().toISOString(),\n    source: 'remotive'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
