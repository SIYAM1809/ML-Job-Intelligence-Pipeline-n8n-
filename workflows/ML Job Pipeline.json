    {
      "parameters": {
        "jsCode": "if (!$input.item.json.choices || !$input.item.json.choices[0]) {\n  return [];\n}\n\nconst raw = $input.item.json.choices[0].message.content;\nconst jobData = $('Dedup Check').item.json;\n\nif (!jobData || !jobData.job_id) {\n  return [];\n}\n\nlet parsed;\ntry {\n  const cleaned = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    score: 0,\n    recommendation: 'skip',\n    match_reasons: ['Parse error'],\n    missing_skills: [],\n    one_line_summary: 'Could not parse LLM response'\n  };\n}\n\nreturn [{\n  json: {\n    ...jobData,\n    score: Number(parsed.score),\n    recommendation: parsed.recommendation,\n    match_reasons: parsed.match_reasons || [],\n    missing_skills: parsed.missing_skills || [],\n    one_line_summary: parsed.one_line_summary || ''\n  }\n}];"
      },
