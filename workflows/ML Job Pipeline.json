    {
      "parameters": {
        "jsCode": "const sheetRows = $('Read Existing Job').all();\nconst existingIds = new Set(\n  sheetRows\n    .filter(i => i.json && i.json.job_id)\n    .map(i => String(i.json.job_id).trim())\n);\n\nconst currentJob = $input.item.json;\n\nif (!currentJob.job_id) {\n  return [];\n}\n\nconst currentId = String(currentJob.job_id).trim();\n\nif (existingIds.has(currentId)) {\n  return [];\n}\n\nreturn [{ json: currentJob }];"
      },
